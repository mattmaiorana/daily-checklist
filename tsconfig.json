{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2018",
    "allowSyntheticDefaultImports": true,
    "importHelpers": true,
    "strict": true,
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "lib": ["ES2019", "DOM"]
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}
